{
  "name": "yamlconfig-frontend",
  "version": "1.0.0",
  "private": true,
  "description": "Local frontend asset pipeline for YAMLconfig",
  "scripts": {
    "build": "npm run build:css && npm run build:vendor",
    "build:css": "tailwindcss -c ./tailwind.config.js -i ./static_src/src/input.css -o ./static/css/app.css --minify",
    "build:vendor": "node ./scripts/copy-vendor.mjs",
    "watch:css": "tailwindcss -c ./tailwind.config.js -i ./static_src/src/input.css -o ./static/css/app.css --watch"
  },
  "dependencies": {
    "alpinejs": "3.15.12",
    "codemirror": "5.65.21"
  },
  "devDependencies": {
    "tailwindcss": "3.4.19"
  }
}
